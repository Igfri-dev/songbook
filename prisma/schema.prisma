generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
}

model User {
  id             Int              @id @default(autoincrement())
  name           String           @db.VarChar(120)
  email          String           @unique @db.VarChar(191)
  username       String           @unique @db.VarChar(80)
  passwordHash   String?          @map("passwordHash") @db.VarChar(191)
  role           Role             @default(ADMIN)
  createdAt      DateTime         @default(now()) @map("createdAt")
  updatedAt      DateTime         @updatedAt @map("updatedAt")
  createdInvites UserInvitation[] @relation("InviteCreator")

  @@map("users")
}

model UserInvitation {
  id          Int       @id @default(autoincrement())
  email       String    @db.VarChar(191)
  username    String    @db.VarChar(80)
  tokenHash   String    @unique @map("tokenHash") @db.VarChar(191)
  expiresAt   DateTime  @map("expiresAt")
  acceptedAt  DateTime? @map("acceptedAt")
  createdById Int?      @map("createdById")
  createdBy   User?     @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("createdAt")
  updatedAt   DateTime  @updatedAt @map("updatedAt")

  @@index([email])
  @@index([expiresAt])
  @@index([createdById])
  @@map("user_invitations")
}

model SongCategory {
  id        Int            @id @default(autoincrement())
  name      String         @db.VarChar(140)
  slug      String         @unique @db.VarChar(191)
  parentId  Int?           @map("parentId")
  parent    SongCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  SongCategory[] @relation("CategoryTree")
  sortOrder Int            @default(0) @map("sortOrder")
  createdAt DateTime       @default(now()) @map("createdAt")
  updatedAt DateTime       @updatedAt @map("updatedAt")
  songs     CategorySong[]

  @@index([parentId, sortOrder])
  @@map("song_categories")
}

model Song {
  id             Int           @id @default(autoincrement())
  title          String        @db.VarChar(180)
  slug           String        @unique @db.VarChar(191)
  hasChords      Boolean       @default(true) @map("hasChords")
  isPublished    Boolean       @default(false) @map("isPublished")
  contentVersion DateTime      @default(now()) @map("contentVersion")
  createdAt      DateTime      @default(now()) @map("createdAt")
  updatedAt      DateTime      @updatedAt @map("updatedAt")
  content        SongContent?
  categories     CategorySong[]

  @@index([isPublished, contentVersion])
  @@map("songs")
}

model SongContent {
  id          Int      @id @default(autoincrement())
  songId      Int      @unique @map("songId")
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  contentJson Json     @map("contentJson")
  createdAt   DateTime @default(now()) @map("createdAt")
  updatedAt   DateTime @updatedAt @map("updatedAt")

  @@map("song_contents")
}

model CategorySong {
  id         Int          @id @default(autoincrement())
  categoryId Int          @map("categoryId")
  songId     Int          @map("songId")
  sortOrder  Int          @default(0) @map("sortOrder")
  category   SongCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  song       Song         @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([categoryId, songId])
  @@index([categoryId, sortOrder])
  @@index([songId])
  @@map("category_songs")
}

model CatalogVersion {
  id          Int      @id @default(autoincrement())
  mainVersion DateTime @map("mainVersion")
  publishedAt DateTime @default(now()) @map("publishedAt")
  notes       String?  @db.Text

  @@index([mainVersion])
  @@map("catalog_versions")
}
